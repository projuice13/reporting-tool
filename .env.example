# WooCommerce REST API credentials (server-side only — never exposed to the browser).
# Generate a READ-ONLY key in WooCommerce -> Settings -> Advanced -> REST API.

WC_STORE_URL=https://projuice.co.uk        # no trailing slash
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxx  # READ-ONLY key
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxx

# Optional: default order statuses to include when the client doesn't specify.
WC_ORDER_STATUSES=processing,completed

# Database (for the persistent cohort tracker). On Vercel, add a Neon Postgres
# store to the project and this is injected automatically. For local dev, paste
# your Neon connection string here (POSTGRES_URL also works as a fallback).
DATABASE_URL=postgres://user:password@ep-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# Site login (single shared username + password, HTTP Basic Auth). Set BOTH to
# turn protection on; leave unset to disable the login gate.
SITE_USER=projuice
SITE_PASSWORD=change-me-to-a-long-shared-password
